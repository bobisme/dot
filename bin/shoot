#!/usr/bin/env bash

set -euo pipefail
export SCREENSHOT_DIR="$HOME/shots"

is_wayland() {
  [[ "${XDG_SESSION_TYPE:-}" = "wayland" ]] || [[ -n "${WAYLAND_DISPLAY:-}" ]]
}

capture_wayland() {
  local outpath="$1"
  grim -g "$(slurp)" "$outpath"
  wl-copy <"$outpath"
}

capture_x11() {
  local outpath="$1"
  scrot -s "$outpath"
  xclip -selection clipboard -t image/png -i "$outpath"
}

capture() {
  if is_wayland; then
    capture_wayland "$outpath"
  else
    capture_x11 "$outpath"
  fi
}

notify() {
  local outpath="$1"
  local shortpath="~${outpath#~}"
  local msg="Screenshot copied to clipboard and saved to:\n$shortpath"
  echo -e "$msg"
  if command -v dunstify >/dev/null 2>&1; then
    local result
    result=$(dunstify --action=open,Open --appname shoot --icon "$outpath" "Screenshot Taken" "$msg")
    if [[ "$result" = 2 ]]; then
      if command -v satty; then
        satty --filename "$outpath"
      else
        local fman
        fman="$(xdg-mime query default inode/directory)"
        case "$fman" in
        *thunar*) thunar "$outpath" ;;
        *) xdg-open "$SCREENSHOT_DIR" ;;
        esac
      fi
    fi
  elif command -v notify-send >/dev/null 2>&1; then
    notify-send --app-name shoot --icon "$outpath" "Screenshot Taken" "$msg"
  fi
}

main() {
  mkdir -p "$SCREENSHOT_DIR"
  local datefile
  datefile="$(date +%Y-%m-%d_%H:%M:%S.png)"
  local outpath="$SCREENSHOT_DIR/$datefile"
  capture "$outpath"
  notify "$outpath" &
}

main "$@"
